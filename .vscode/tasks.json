{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "$(check) pre-commit run --all",
            "type": "shell",
            "command": "uv run pre-commit run --all-files",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "options": {
                "statusbar": {
                    "color": "#E8F5E8"
                }
            },
            "problemMatcher": []
        },
        {
            "label": "$(server-process) start local server",
            "type": "shell",
            "command": "uv run uvicorn drm_document_service.app:app --host 127.0.0.1 --port 8000 --reload",
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "options": {
                "statusbar": {
                    "color": "#E8F5E8"
                }
            },
            "problemMatcher": []
        },
        {
            "label": "$(play) start doc-service",
            "type": "shell",
            "command": "docker compose -f doc-service.compose.yaml -p doc-service up",
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "options": {
                "statusbar": {
                    "color": "#E3F2FD"
                }
            },
            "problemMatcher": []
        },
        {
            "label": "$(stop) stop doc-service",
            "type": "shell",
            "command": "docker compose -f doc-service.compose.yaml -p doc-service down",
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "options": {
                "statusbar": {
                    "color": "#FFEBEE"
                }
            },
            "problemMatcher": []
        },
        {
            "label": "$(refresh) rebuild doc-service",
            "type": "shell",
            "command": "docker compose -f doc-service.compose.yaml -p doc-service down && docker compose -f doc-service.compose.yaml -p doc-service build --no-cache && docker compose -f doc-service.compose.yaml -p doc-service up",
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "options": {
                "statusbar": {
                    "color": "#FFF3E0"
                }
            },
            "problemMatcher": []
        }
    ]
}
